<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Store.SignUpController">
   <children>
      <AnchorPane layoutX="-5.0" layoutY="-3.0" prefHeight="404.0" prefWidth="515.0">
         <children>
            <Label layoutX="54.0" layoutY="174.0" prefHeight="30.0" prefWidth="161.0" text="Enter User Name">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <TextField fx:id="IdField" layoutX="232.0" layoutY="173.0" promptText="Enter Your Name">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
            <Button fx:id="BackButton" layoutX="54.0" layoutY="223.0" mnemonicParsing="false" onAction="#BackLogin" text="Back" />
            <Button fx:id="AddButton" layoutX="379.0" layoutY="223.0" mnemonicParsing="false" onAction="#SignUp" text="Add" />
         </children>
      </AnchorPane>
   </children>
</AnchorPane>
